<section class="v2-section v2-contact" id="cnt">
  <div class="v2-eyebrow">— Capítulo 04 — Final</div>
  <h2 class="v2-contact-title">
    Deja de leer.<br/>
    <em>Empieza a</em><br/>
    facturar.
  </h2>
  <div class="v2-contact-grid">
    <div class="v2-contact-info">
      <p>
        Cuéntanos qué necesitas. Respondemos en menos de 24 horas con propuesta concreta
        y precio cerrado. Sin "vamos a explorar sinergias".
      </p>
      <div class="v2-contact-meta">
        <div><strong>Email</strong> kninfodigital@gmail.com</div>
        <div><strong>Tel.</strong> +376 655 708</div>
        <div><strong>HQ</strong> Escaldes-Engordany, Andorra</div>
        <div><strong>IG</strong> @alejandrompc_</div>
      </div>
    </div>
    <form class="v2-contact-form" action="https://api.web3forms.com/submit" method="POST">
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />
      <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
      <input type="hidden" name="subject" value="Nuevo contacto desde knowin.es" />

      <label>
        <span>Nombre</span>
        <input name="name" required placeholder="Cómo te llamas" autocomplete="name" />
      </label>
      <label>
        <span>Empresa</span>
        <input name="company" placeholder="Tu negocio" />
      </label>
      <label>
        <span>Email</span>
        <input type="email" name="email" required placeholder="tu@email.com" autocomplete="email" />
      </label>
      <label>
        <span>Presupuesto</span>
        <select name="budget">
          <option value="" disabled selected>Selecciona...</option>
          <option>&lt; 2.000€</option>
          <option>2.000 - 5.000€</option>
          <option>5.000 - 10.000€</option>
          <option>&gt; 10.000€</option>
        </select>
      </label>
      <label class="v2-cf-full">
        <span>Cuéntanos</span>
        <textarea name="message" required rows="4" placeholder="Qué necesitas, qué tienes, qué problema resolver..."></textarea>
      </label>
      <button type="submit" class="v2-cf-send">Enviar mensaje →</button>
    </form>
  </div>
</section>
