---
const services = [
  { n: '01', t: 'Webs que convierten', sub: 'Rápidas, SEO, pensadas para vender.', bg: '#caff00', fg: '#0a0a0a' },
  { n: '02', t: 'Landing pages', sub: 'Convierten o iteramos hasta que lo hagan.', bg: '#2b6cff', fg: '#fff' },
  { n: '03', t: 'Automatizaciones', sub: 'Tu equipo deja de copiar-pegar.', bg: '#ff2bd6', fg: '#0a0a0a' },
  { n: '04', t: 'Consultoría digital', sub: 'Qué construir, en qué orden, cómo medir.', bg: '#0a0a0a', fg: '#caff00' },
];
---

<section class="v2-section" id="srv">
  <div class="v2-section-head">
    <div class="v2-eyebrow">— Capítulo 01</div>
    <h2 class="v2-section-title">
      Cuatro<br/>
      <em>servicios.</em><br/>
      Ninguno<br/>
      inflado.
    </h2>
  </div>
  <div class="v2-srv-stack">
    {services.map(s => (
      <a href="#cnt" class="v2-srv-row" style={`--srv-bg:${s.bg};--srv-fg:${s.fg}`}>
        <div class="v2-srv-num">{s.n}</div>
        <div class="v2-srv-name">
          <h3>{s.t}</h3>
          <p>{s.sub}</p>
        </div>
        <div class="v2-srv-arrow">→</div>
        <div class="v2-srv-fill"></div>
      </a>
    ))}
  </div>
</section>
